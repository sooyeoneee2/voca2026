<script>
// ==================== THEME TOGGLE ====================
(function(){
  try {
    if(localStorage.getItem('simpsonVocaTheme') === 'day'){
      document.body.classList.add('day-mode');
      document.getElementById('themeToggle').textContent = '☀️';
    }
  } catch(e){}
})();

function toggleTheme(){
  document.body.classList.toggle('day-mode');
  const btn = document.getElementById('themeToggle');
  const isDay = document.body.classList.contains('day-mode');
  btn.textContent = isDay ? '☀️' : '🌙';
  btn.title = isDay ? '다크 모드로 전환' : '라이트 모드로 전환';
  try { localStorage.setItem('simpsonVocaTheme', isDay ? 'day' : 'night'); } catch(e){}
}

// ==================== 성취율 TRACKING ====================
let completedDays = {};
try {
  const saved = localStorage.getItem('simpsonVocaCompleted');
  if(saved) completedDays = JSON.parse(saved);
  // Migrate old format (true → score)
  for(const k in completedDays){
    if(completedDays[k] === true) completedDays[k] = 100;
  }
} catch(e){}

function saveCompleted(){
  try {
    if(Object.keys(completedDays).length === 0){
      localStorage.removeItem('simpsonVocaCompleted');
    } else {
      localStorage.setItem('simpsonVocaCompleted', JSON.stringify(completedDays));
    }
  } catch(e){}
}

function updateAchievement(){
  const count = Object.keys(completedDays).length;
  document.getElementById('achCount').textContent = count;
  // Update day buttons
  document.querySelectorAll('.day-btn').forEach(b => {
    const dayNum = parseInt(b.dataset.day);
    const scoreEl = b.querySelector('.day-score');
    if(completedDays[dayNum] !== undefined){
      const pct = completedDays[dayNum];
      b.classList.add('completed');
      scoreEl.textContent = pct + '%';
      scoreEl.className = 'day-score ' + (pct >= 80 ? 'score-good' : pct >= 50 ? 'score-mid' : 'score-bad');
    } else {
      b.classList.remove('completed');
      scoreEl.textContent = '';
      scoreEl.className = 'day-score';
    }
  });
}

function markDayCompleted(day, pct){
  if(typeof day === 'number'){
    completedDays[day] = pct;
  } else if(typeof day === 'string' && day.includes('-')){
    const [from, to] = day.split('-').map(Number);
    for(let d = from; d <= to; d++) completedDays[d] = pct;
  }
  saveCompleted();
  updateAchievement();
}

// Init on load
updateAchievement();

function resetAll(){
  const btn = document.querySelector('.reset-btn');
  if(btn.dataset.confirm !== 'true'){
    btn.dataset.confirm = 'true';
    btn.textContent = '정말 초기화할까요? (다시 누르면 실행)';
    btn.style.borderColor = 'var(--wrong)';
    btn.style.color = 'var(--wrong)';
    setTimeout(() => {
      btn.dataset.confirm = '';
      btn.textContent = '기록 초기화 (새 회독)';
      btn.style.borderColor = '';
      btn.style.color = '';
    }, 3000);
    return;
  }
  completedDays = {};
  saveCompleted();
  updateAchievement();
  btn.dataset.confirm = '';
  btn.textContent = '초기화 완료!';
  btn.style.borderColor = 'var(--correct)';
  btn.style.color = 'var(--correct)';
  setTimeout(() => {
    btn.textContent = '기록 초기화 (새 회독)';
    btn.style.borderColor = '';
    btn.style.color = '';
  }, 1500);
}

