<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>2026 심슨보카 단어 테스트</title>
<link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --card: #14141f;
  --card-hover: #1a1a2e;
  --accent: #6c5ce7;
  --accent2: #a29bfe;
  --correct: #00b894;
  --wrong: #e17055;
  --text: #f0f0f5;
  --text-dim: #8888aa;
  --border: #2a2a3e;
  --word-text: #fff;
  --gradient-start: #fff;
}
body.day-mode {
  --bg: #f0f0f5;
  --card: #ffffff;
  --card-hover: #f5f3ff;
  --accent: #6c5ce7;
  --accent2: #5a4bd1;
  --correct: #00a884;
  --wrong: #d35400;
  --text: #1a1a2e;
  --text-dim: #6b6b8a;
  --border: #d8d8e8;
  --word-text: #1a1a2e;
  --gradient-start: #1a1a2e;
}
body.day-mode::before {
  background: radial-gradient(ellipse at 30% 20%, rgba(108,92,231,0.06) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 80%, rgba(162,155,254,0.04) 0%, transparent 50%);
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  font-weight: 500;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  min-height: -webkit-fill-available;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  padding: env(safe-area-inset-top, 0) env(safe-area-inset-right, 0) env(safe-area-inset-bottom, 0) env(safe-area-inset-left, 0);
}
body::before {
  content: '';
  position: fixed;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(ellipse at 30% 20%, rgba(108,92,231,0.08) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 80%, rgba(162,155,254,0.05) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
}

.container {
  max-width: 720px;
  margin: 0 auto;
  padding: 20px;
  position: relative;
  z-index: 1;
}

/* HEADER */
.header {
  text-align: center;
  padding: 20px 0;
}
.header h1 {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--accent2);
  margin-bottom: 8px;
}
.header h2 {
  font-size: 28px;
  font-weight: 900;
  background: linear-gradient(135deg, var(--gradient-start) 0%, var(--accent2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* DAY SELECTOR */
#daySelector {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
  margin-bottom: 30px;
  padding: 20px;
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
}
.day-btn {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-dim);
  padding: 10px 4px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 12px;
  font-weight: 500;
  transition: all 0.2s;
  font-family: 'Space Mono', monospace;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  line-height: 1.2;
}
.day-btn .day-num {
  font-size: 13px;
  font-weight: 700;
}
.day-btn .day-score {
  font-size: 9px;
  display: none;
}
.day-btn.completed .day-score {
  display: block;
}
.day-btn .day-score.score-good { color: var(--correct); }
.day-btn .day-score.score-mid { color: #fdcb6e; }
.day-btn .day-score.score-bad { color: var(--wrong); }
.day-btn:hover {
  background: var(--card-hover);
  color: var(--text);
  border-color: var(--accent);
}
.day-btn.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}
.day-btn.completed {
  background: rgba(0,184,148,0.15);
  border-color: var(--correct);
  color: var(--correct);
}

/* QUIZ AREA */
#quizArea { display: none; }

.quiz-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  padding: 16px 20px;
  background: var(--card);
  border-radius: 12px;
  border: 1px solid var(--border);
}
.quiz-day-label {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  color: var(--accent2);
  letter-spacing: 2px;
}
.quiz-progress {
  font-size: 13px;
  color: var(--text-dim);
}
.quiz-progress span { color: var(--accent2); font-weight: 700; }

/* PROGRESS BAR */
.progress-bar-wrap {
  width: 100%;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  margin-bottom: 24px;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 2px;
  transition: width 0.4s ease;
}

/* WORD CARD */
.word-card {
  text-align: center;
  padding: 48px 24px;
  margin-bottom: 24px;
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.word-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent));
}
.word-number {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 3px;
  margin-bottom: 16px;
}
.word-text {
  font-family: 'Pretendard', sans-serif;
  font-size: 36px;
  font-weight: 700;
  color: var(--word-text);
  letter-spacing: 1px;
}

/* OPTIONS */
.options {
  display: grid;
  gap: 10px;
  margin-bottom: 20px;
}
.option-btn {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 16px 20px;
  border-radius: 12px;
  cursor: pointer;
  font-size: 15px;
  line-height: 1.5;
  text-align: left;
  transition: all 0.2s;
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.option-btn:hover:not(.disabled) {
  background: var(--card-hover);
  border-color: var(--accent);
  transform: translateY(-1px);
}
.option-label {
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  color: var(--accent2);
  min-width: 20px;
  padding-top: 2px;
}
.option-btn.correct {
  background: rgba(0,184,148,0.12);
  border-color: var(--correct);
  color: var(--correct);
}
.option-btn.wrong {
  background: rgba(225,112,85,0.12);
  border-color: var(--wrong);
  color: var(--wrong);
}
.option-btn.disabled { pointer-events: none; }
.option-btn.disabled:not(.correct):not(.wrong) { opacity: 0.4; }

/* RESULT */
#resultArea {
  display: none;
  text-align: center;
  padding: 48px 24px;
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
  margin-top: 20px;
}
.result-day-label {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  letter-spacing: 3px;
  color: var(--accent2);
  margin-bottom: 12px;
  text-transform: uppercase;
}
.result-score {
  font-family: 'Space Mono', monospace;
  font-size: 64px;
  font-weight: 700;
  margin-bottom: 8px;
}
.result-score.good { color: var(--correct); }
.result-score.mid { color: #fdcb6e; }
.result-score.bad { color: var(--wrong); }
.result-label {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 4px;
}
.result-sub {
  font-size: 14px;
  color: var(--text-dim);
  margin-bottom: 24px;
}
.result-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
.btn {
  padding: 12px 24px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--card-hover);
  color: var(--text);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}
.btn:hover { border-color: var(--accent); background: var(--accent); color: #fff; }
.btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
.btn.primary:hover { background: var(--accent2); border-color: var(--accent2); }

/* WRONG REVIEW */
#wrongReview { display: none; margin-top: 20px; }
.wrong-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  background: var(--card);
  border-radius: 10px;
  border: 1px solid var(--border);
  margin-bottom: 8px;
}
.wrong-word {
  font-family: 'Space Mono', monospace;
  font-weight: 700;
  font-size: 15px;
  color: var(--accent2);
}
.wrong-meaning {
  font-size: 13px;
  color: var(--text-dim);
  text-align: right;
  max-width: 60%;
}

/* MODE SELECTOR */
.mode-selector {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  justify-content: center;
}
.mode-btn {
  padding: 8px 18px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-dim);
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}
.mode-btn.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}

/* RANGE SELECTOR */
.range-wrap {
  display: none;
  gap: 8px;
  margin-bottom: 20px;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}
.range-wrap.show { display: flex; }
.range-wrap label { font-size: 13px; color: var(--text-dim); }
.range-wrap select {
  padding: 6px 12px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--card);
  color: var(--text);
  font-size: 13px;
}
.range-start-btn {
  padding: 10px 28px;
  border-radius: 10px;
  border: none;
  background: var(--accent);
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 8px;
}
.range-start-btn:hover { background: var(--accent2); }

/* RESET BUTTON */
.reset-wrap {
  text-align: center;
  margin-bottom: 30px;
}
.reset-btn {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-dim);
  padding: 10px 20px;
  border-radius: 10px;
  font-size: 12px;
  font-family: 'Pretendard', sans-serif;
  cursor: pointer;
  transition: all 0.2s;
}
.reset-btn:hover {
  border-color: var(--wrong);
  color: var(--wrong);
  background: rgba(225,112,85,0.08);
}

/* THEME TOGGLE & TOP BAR */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  z-index: 10;
  padding: 10px 0;
}
.achievement-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 8px 14px;
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  color: var(--accent2);
  white-space: nowrap;
  transition: all 0.3s;
}
.achievement-badge .ach-icon {
  font-size: 14px;
}
.achievement-badge .ach-num {
  font-weight: 700;
  color: var(--correct);
}
.theme-toggle {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--text);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.theme-toggle:hover {
  border-color: var(--accent);
  background: var(--card-hover);
}

/* Mobile optimization */
@media (max-width: 480px) {
  .word-text { font-size: 26px; word-break: break-word; }
  #daySelector { grid-template-columns: repeat(5, 1fr); gap: 8px; padding: 16px; }
  .day-btn { padding: 10px 4px 8px; min-height: 50px; }
  .day-btn .day-num { font-size: 12px; }
  .day-btn .day-score { font-size: 8px; }
  .container { padding: 12px; padding-bottom: env(safe-area-inset-bottom, 20px); }
  .header { padding: 12px 0 16px; }
  .header h1 { font-size: 12px; letter-spacing: 4px; }
  .header h2 { font-size: 22px; }
  .word-card { padding: 36px 16px; }
  .option-btn { padding: 16px 16px; font-size: 15px; min-height: 52px; -webkit-tap-highlight-color: transparent; }
  .btn { padding: 14px 20px; font-size: 14px; min-height: 48px; width: 100%; }
  .result-btns { flex-direction: column; gap: 8px; padding: 0 8px; }
  .result-score { font-size: 56px; }
  .quiz-header { padding: 12px 16px; flex-wrap: wrap; gap: 8px; }
  .mode-btn { padding: 10px 16px; font-size: 13px; min-height: 44px; }
  .top-bar { gap: 6px; }
  .achievement-badge { padding: 6px 10px; font-size: 11px; }
  .theme-toggle { width: 40px; height: 40px; font-size: 18px; }
  .reset-btn { font-size: 12px; padding: 12px 16px; min-height: 44px; }
  .range-wrap select { min-height: 44px; font-size: 14px; padding: 8px 12px; }
  .range-start-btn { min-height: 48px; width: 100%; font-size: 15px; padding: 14px 28px; }
  .wrong-item { padding: 12px 14px; flex-wrap: wrap; gap: 6px; }
  .wrong-word { font-size: 14px; }
  .wrong-meaning { font-size: 12px; max-width: 100%; text-align: left; }
  .wrong-retry-wrap { padding: 0 8px; }
  .wrong-retry-wrap .btn { width: 100%; }
}

/* iOS Safari specific fixes */
@supports (-webkit-touch-callout: none) {
  body { -webkit-text-size-adjust: 100%; }
  .option-btn { -webkit-appearance: none; }
  .btn { -webkit-appearance: none; }
  input, select, button { font-size: 16px; }
}

/* Prevent double-tap zoom on buttons */
button { touch-action: manipulation; }
select { touch-action: manipulation; }
</style>
</head>
