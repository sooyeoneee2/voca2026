// ==================== QUIZ LOGIC ====================
let currentDay = 0;
let questions = [];
let currentQ = 0;
let score = 0;
let wrongList = [];
let mode = 'day';

function setMode(m){
  mode = m;
  document.querySelectorAll('.mode-btn').forEach((b,i) => {
    b.classList.toggle('active', (i===0 && m==='day') || (i===1 && m==='range'));
  });
  document.getElementById('daySelector').style.display = m==='day' ? 'grid' : 'none';
  document.getElementById('rangeWrap').classList.toggle('show', m==='range');
}

function startRange(){
  const from = parseInt(document.getElementById('rangeFrom').value);
  const to = parseInt(document.getElementById('rangeTo').value);
  if(from > to){ alert('시작 Day가 끝 Day보다 클 수 없습니다.'); return; }
  let allWords = [];
  for(let d = from; d <= to; d++){
    if(DATA[d]) allWords = allWords.concat(DATA[d]);
  }
  currentDay = `${from}-${to}`;
  buildQuiz(allWords, `DAY ${from} ~ ${to}`);
}

function startQuiz(day){
  currentDay = day;
  const btns = document.querySelectorAll('.day-btn');
  btns.forEach(b => {
    b.classList.toggle('active', parseInt(b.dataset.day) === day);
  });
  buildQuiz(DATA[day], `DAY ${String(day).padStart(2,'0')}`);
}

function buildQuiz(words, label){
  // Shuffle words
  const shuffled = [...words].sort(() => Math.random() - 0.5);
  questions = shuffled.map(([word, meaning]) => {
    // Pick 3 wrong answers from same dataset
    let wrongs = words.filter(w => w[0] !== word).sort(() => Math.random()-0.5).slice(0,3).map(w=>w[1]);
    let opts = [...wrongs, meaning].sort(() => Math.random()-0.5);
    return { word, meaning, options: opts };
  });

  currentQ = 0;
  score = 0;
  wrongList = [];

  document.getElementById('quizDayLabel').textContent = label;
  document.getElementById('qTotal').textContent = questions.length;
  document.getElementById('daySelector').style.display = 'none';
  document.getElementById('rangeWrap').classList.remove('show');
  document.querySelector('.mode-selector').style.display = 'none';
  document.getElementById('resetWrap').style.display = 'none';
  document.getElementById('quizArea').style.display = 'block';
  document.getElementById('resultArea').style.display = 'none';
  document.getElementById('wrongReview').style.display = 'none';

  showQuestion();
}

function showQuestion(){
  const q = questions[currentQ];
  document.getElementById('qCurrent').textContent = currentQ + 1;
  document.getElementById('wordNumber').textContent = `QUESTION ${String(currentQ+1).padStart(2,'0')}`;
  document.getElementById('wordText').textContent = q.word;
  document.getElementById('progressBar').style.width = ((currentQ)/questions.length*100)+'%';

  const area = document.getElementById('optionsArea');
  area.innerHTML = '';
  const labels = ['A','B','C','D'];
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-label">${labels[i]}</span><span>${opt}</span>`;
    btn.onclick = () => selectAnswer(btn, opt, q);
    area.appendChild(btn);
  });
}

function selectAnswer(btn, selected, q){
  const btns = document.querySelectorAll('.option-btn');
  btns.forEach(b => {
    b.classList.add('disabled');
    if(b.querySelector('span:last-child').textContent === q.meaning) b.classList.add('correct');
  });
  if(selected === q.meaning){
    score++;
  } else {
    btn.classList.add('wrong');
    wrongList.push({ word: q.word, meaning: q.meaning });
  }

  setTimeout(() => {
    currentQ++;
    if(currentQ < questions.length) showQuestion();
    else showResult();
  }, 300);
}

function showResult(){
  document.getElementById('quizArea').style.display = 'none';
  document.getElementById('resultArea').style.display = 'block';

  // Show which day this result is for
  let dayLabel = '';
  if(typeof currentDay === 'string' && currentDay.includes('-')){
    const [from, to] = currentDay.split('-');
    dayLabel = `DAY ${from} ~ ${to}`;
  } else {
    dayLabel = `DAY ${String(currentDay).padStart(2,'0')}`;
  }
  document.getElementById('resultDayLabel').textContent = dayLabel + ' 결과';

  const pct = Math.round(score/questions.length*100);
  const el = document.getElementById('resultScore');
  el.textContent = pct + '%';
  el.className = 'result-score ' + (pct >= 80 ? 'good' : pct >= 50 ? 'mid' : 'bad');

  document.getElementById('resultLabel').textContent =
    pct >= 90 ? '완벽에 가깝습니다!' :
    pct >= 80 ? '훌륭합니다!' :
    pct >= 60 ? '조금 더 힘내세요!' : '복습이 필요합니다!';

  document.getElementById('resultSub').textContent =
    `${questions.length}문제 중 ${score}개 정답`;

  // Show/hide retry wrong button
  document.getElementById('retryWrongBtn').style.display = wrongList.length > 0 ? 'inline-block' : 'none';

  // Mark day as completed
  markDayCompleted(currentDay, pct);
}

function showWrongReview(){
  const area = document.getElementById('wrongReview');
  area.style.display = 'block';
  const list = document.getElementById('wrongList');
  list.innerHTML = '';
  const retryWrap = document.getElementById('wrongRetryWrap');
  if(wrongList.length === 0){
    list.innerHTML = '<p style="color:var(--correct);text-align:center;padding:20px;">틀린 문제가 없습니다!</p>';
    retryWrap.style.display = 'none';
    return;
  }
  retryWrap.style.display = 'block';
  wrongList.forEach(w => {
    const d = document.createElement('div');
    d.className = 'wrong-item';
    d.innerHTML = `<span class="wrong-word">${w.word}</span><span class="wrong-meaning">${w.meaning}</span>`;
    list.appendChild(d);
  });
}

function retryWrong(){
  if(wrongList.length === 0){ alert('틀린 문제가 없습니다!'); return; }
  // Build quiz from wrong answers only, using full word pool for wrong options
  const wrongWords = wrongList.map(w => [w.word, w.meaning]);
  // Gather all available words for generating wrong options
  let allWords = [];
  if(typeof currentDay === 'string'){
    const [from,to] = currentDay.split('-').map(Number);
    for(let d = from; d <= to; d++) if(DATA[d]) allWords = allWords.concat(DATA[d]);
  } else {
    allWords = DATA[currentDay] ? [...DATA[currentDay]] : [];
  }
  // Shuffle wrong words
  const shuffled = [...wrongWords].sort(() => Math.random() - 0.5);
  questions = shuffled.map(([word, meaning]) => {
    let wrongs = allWords.filter(w => w[0] !== word).sort(() => Math.random()-0.5).slice(0,3).map(w=>w[1]);
    let opts = [...wrongs, meaning].sort(() => Math.random()-0.5);
    return { word, meaning, options: opts };
  });

  currentQ = 0;
  score = 0;
  wrongList = [];

  const label = typeof currentDay === 'string' ? `DAY ${currentDay.replace('-',' ~ ')} (오답)` : `DAY ${String(currentDay).padStart(2,'0')} (오답)`;
  document.getElementById('quizDayLabel').textContent = label;
  document.getElementById('qTotal').textContent = questions.length;
  document.getElementById('daySelector').style.display = 'none';
  document.getElementById('rangeWrap').classList.remove('show');
  document.querySelector('.mode-selector').style.display = 'none';
  document.getElementById('resetWrap').style.display = 'none';
  document.getElementById('quizArea').style.display = 'block';
  document.getElementById('resultArea').style.display = 'none';
  document.getElementById('wrongReview').style.display = 'none';

  showQuestion();
}

function retryQuiz(){
  if(typeof currentDay === 'string'){
    const [from,to] = currentDay.split('-').map(Number);
    let allWords = [];
    for(let d = from; d <= to; d++) if(DATA[d]) allWords = allWords.concat(DATA[d]);
    buildQuiz(allWords, `DAY ${from} ~ ${to}`);
  } else {
    startQuiz(currentDay);
  }
}

function goHome(){
  document.getElementById('quizArea').style.display = 'none';
  document.getElementById('resultArea').style.display = 'none';
  document.getElementById('wrongReview').style.display = 'none';
  document.getElementById('daySelector').style.display = 'grid';
  document.querySelector('.mode-selector').style.display = 'flex';
  document.getElementById('resetWrap').style.display = 'block';
  document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
  updateAchievement();
}
</script>
